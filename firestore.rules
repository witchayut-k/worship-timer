rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function isController() {
      return isAuthed() && request.auth.token.role == 'controller';
    }

    function isOwner() {
      return isAuthed() && request.auth.uid == resource.data.ownerUid;
    }

    function isOwnerOnCreate() {
      return isAuthed() && request.auth.uid == request.resource.data.ownerUid;
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isController() || isOwnerOnCreate();
      allow update, delete: if isController() || isOwner();

      match /programItems/{itemId} {
        allow read: if true;
        allow create, update, delete: if isController() || isOwner();
      }

      match /runtime/{docId} {
        allow read: if true;
        allow create, update, delete: if isController() || isOwner();
      }
    }
  }
}

